# ============================================
# Quantix AI Core - Multi-Agent Edition v4.0
# Environment Configuration Template
# ============================================

# --- Application ---
APP_NAME="Quantix AI Core - Multi-Agent Edition"
APP_VERSION="4.0.0"
DEBUG=false
INSTANCE_NAME=LOCAL-DEV

# --- Supabase Database ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Redis Message Bus ---
REDIS_URL=redis://localhost:6379/0

# --- Telegram Notifications ---
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id
TELEGRAM_ADMIN_CHAT_ID=your-admin-chat-id

# --- Market Data API Keys ---
TWELVE_DATA_API_KEY=your-twelve-data-key

# --- Agent Configuration ---
AGENT_HEARTBEAT_INTERVAL=60
AGENT_HEARTBEAT_TIMEOUT=900
DATA_FETCH_INTERVAL=300
WATCHER_CHECK_INTERVAL=60

# --- Trading Rules ---
MIN_CONFIDENCE=0.80
MIN_RR=1.0
MAX_PENDING_DURATION_MINUTES=35
MAX_TRADE_DURATION_MINUTES=180
MIN_RELEASE_INTERVAL_MINUTES=20
